# ============================================================
# LLM Provider 选择（必须设置一项）
# 可选：anthropic / openai / gemini / local / dashscope / deepseek / kimi / minimax
# ============================================================
LLM_PROVIDER=anthropic

# ---------- Anthropic (Claude) ----------
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ---------- OpenAI (GPT-4o / o1 / Groq / LM Studio 等) ----------
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com

# ---------- Google Gemini ----------
GEMINI_API_KEY=xxxxx
GEMINI_MODEL=gemini-2.0-flash

# ---------- 本地模型 (Ollama / LM Studio 等) ----------
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5
LOCAL_LLM_API_KEY=not-needed

# ---------- 阿里云 DashScope (通义千问等) ----------
DASHSCOPE_API_KEY=sk-xxxxx
DASHSCOPE_MODEL=qwen-long

# ---------- DeepSeek ----------
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- Kimi / Moonshot AI ----------
KIMI_API_KEY=sk-xxxxx
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ---------- MiniMax ----------
MINIMAX_API_KEY=xxxxx
MINIMAX_MODEL=abab6.5s-chat
MINIMAX_BASE_URL=https://api.minimax.chat/v

# ============================================================
# 通用参数
# ============================================================
MAX_TOKENS=4096
TEMPERATURE=0.7
